{
	"name": "@pibun/monorepo",
	"private": true,
	"packageManager": "bun@1.2.21",
	"workspaces": ["apps/*", "packages/*"],
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"dev:server": "turbo run dev --filter=@pibun/server",
		"dev:web": "turbo run dev --filter=@pibun/web",
		"dev:desktop": "turbo run dev --filter=@pibun/desktop",
		"build:web": "turbo run build --filter=@pibun/web",
		"build:desktop": "cd apps/desktop && npx electrobun build --env=stable",
		"build:desktop:canary": "cd apps/desktop && npx electrobun build --env=canary",
		"build:desktop:signed": "cd apps/desktop && bun scripts/build-signed.ts",
		"build:desktop:signed:canary": "cd apps/desktop && bun scripts/build-signed.ts --env=canary",
		"build:desktop:linux": "cd apps/desktop && bun scripts/build-linux.ts",
		"build:desktop:linux:canary": "cd apps/desktop && bun scripts/build-linux.ts --env=canary",
		"build:desktop:windows": "cd apps/desktop && bun scripts/build-windows.ts",
		"build:desktop:windows:canary": "cd apps/desktop && bun scripts/build-windows.ts --env=canary",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test:smoke": "bun run apps/server/src/smoke-test.ts",
		"test:smoke:multi-session": "bun run apps/server/src/multi-session-test.ts",
		"test:smoke:git": "bun run apps/server/src/git-integration-test.ts",
		"test:smoke:projects": "bun run apps/server/src/project-verify-test.ts",
		"test:smoke:artifacts": "cd apps/desktop && bun scripts/smoke-test.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.4.4",
		"typescript": "^5.8.2"
	},
	"trustedDependencies": ["@biomejs/biome", "esbuild"]
}
